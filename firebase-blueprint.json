{
  "entities": {
    "Channel": {
      "title": "Channel",
      "description": "An IPTV channel stream",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "logo": { "type": "string" },
        "category": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "isHidden": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "url", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Channel category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "AppSetting": {
      "title": "App Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "value": { "type": "object" }
      }
    },
    "User": {
      "title": "User",
      "description": "Registered application user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "owner"] },
        "plusActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name"]
    }
  },
  "firestore": {
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Collection of all IPTV channels"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of channel categories"
    },
    "/settings/{settingKey}": {
      "schema": "AppSetting",
      "description": "Global app settings (banner, logo, playlist_url)"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and subscription status"
    }
  }
}
